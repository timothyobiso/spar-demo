.venv/
__pycache__/
*.pyc
.gradio/
.env
.DS_Store
.claude/

# Don't commit the tam Ridge probes — those belong to the separate tam paper
results/qwen3.5-4b/

# Don't commit raw eval dumps (large, not core deliverables)
results/eval_*.json
results/sweep*.json

# Default: no pkls, except the v2/v3 CAA probes we want to publish
*.pkl
!results/qwen3.5-9b-base/probes_caa.pkl
!results/qwen3.5-9b-base/probes_caa_v3.pkl
!results/qwen3.5-9b-base/probes_continuous_v3.pkl

# Don't commit slides (separate deliverable)
slides/

# Don't commit experiment battery raw outputs (large, easy to regenerate)
results/stock_battery_*.jsonl
results/probe_traj_*.jsonl
# Don't commit basic figures or summary CSV (regenerate from JSONL)
results/stock_battery_figs/*.png
results/stock_battery_figs/*.csv
# Do commit the deep findings figures — they tell the story
!results/stock_battery_figs/deep/
